# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/v1
CORS_ORIGINS=http://localhost:3000

# --- PostgreSQL (operational data) ---
DATABASE_URL=postgresql+asyncpg://platform:platform@localhost:5432/platform

# --- ClickHouse (telemetry, append-only; never queried in policy hot path) ---
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=telemetry
# Async batched writer config:
CLICKHOUSE_BATCH_SIZE=100
CLICKHOUSE_FLUSH_INTERVAL_S=5.0
CLICKHOUSE_QUEUE_MAX=10000

# --- Redis (cache, pub/sub, session revocation) ---
REDIS_URL=redis://localhost:6379/0

# --- Redpanda (event streaming — wired in Sprint 7) ---
REDPANDA_BROKERS=localhost:9092

# --- JWT signing ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS_FOR_DEV_ONLY
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# --- Secrets resolver ---
# References use a backend prefix:
#   env:VAR_NAME       — process environment (dev/CI)
#   awssm:secret_name  — AWS Secrets Manager (set AWS_REGION + IAM creds)
#   vault:path         — HashiCorp Vault KV v2 (set VAULT_ADDR + VAULT_TOKEN)
# Example for OIDC: client_secret_ref="env:OIDC_SECRET_OKTA"
AWS_REGION=us-east-1
# VAULT_ADDR=http://vault:8200
# VAULT_TOKEN=
# VAULT_KV_MOUNT=secret
# FIPS_MODE=false  # use FIPS endpoints for AWS Secrets Manager when true

# --- Field-level encryption ---
# Required for the EncryptedInlineResolver (enc:) and the auto-encrypt path
# in IDP admin (enc-pending:<plaintext> → enc:v1:<ciphertext> at storage).
# Generate keys with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Single-key (dev):
#   FIELD_CRYPTO_KEY_REF=env:FIELD_CRYPTO_KEY
#   FIELD_CRYPTO_KEY=<urlsafe-base64-32-bytes>
# Versioned keyring (prod, supports rotation):
#   FIELD_CRYPTO_KEYRING_REF=awssm:platform-field-crypto-keyring
#   (resolved value: "v1:<key>,v2:<key>,v3:<key>")
#   FIELD_CRYPTO_ACTIVE_VERSION=2
FIELD_CRYPTO_KEY_REF=
FIELD_CRYPTO_KEYRING_REF=
FIELD_CRYPTO_ACTIVE_VERSION=

# --- Audit log ---
# Comma-separated backend list. Production: file,siem (or redis,siem).
AUDIT_BACKEND=file
AUDIT_LOG_PATH=./var/audit/audit.jsonl
AUDIT_REDIS_TTL_DAYS=90
# Reference to the HMAC key used for tamper-evident hashing.
# Without this, audit entries fall back to plain SHA-256 (dev only).
# Example: AUDIT_HMAC_KEY_REF=awssm:platform-audit-hmac-key
AUDIT_HMAC_KEY_REF=
AUDIT_SIEM_WEBHOOK_URL=
